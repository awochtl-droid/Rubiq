# Treat all files as text by default, normalize line endings
* text=auto

# Binary files — never touch line endings
*.pdf    binary
*.jpg    binary
*.jpeg   binary
*.png    binary
*.gif    binary
*.ico    binary
*.svg    binary
*.woff   binary
*.woff2  binary
*.ttf    binary
*.otf    binary
*.eot    binary
*.zip    binary
*.gz     binary
*.mp4    binary
*.mp3    binary
